{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.go",
      "use": "@vercel/go"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "src": "/api/health",   "dest": "/api/health/index.go"   },
    { "src": "/api/register", "dest": "/api/register/index.go" },
    { "src": "/api/approve",  "dest": "/api/approve/index.go"  },
    { "src": "/api/status",   "dest": "/api/status/index.go"   },
    { "src": "/api/pending",  "dest": "/api/pending/index.go"  },
    { "src": "/api/approved", "dest": "/api/approved/index.go" },
    { "src": "/api/disabled", "dest": "/api/disabled/index.go" },
    { "src": "/api/disable",  "dest": "/api/disable/index.go"  },
    { "src": "/api/remove",         "dest": "/api/remove/index.go"         },
    { "src": "/api/force-approve",  "dest": "/api/force-approve/index.go"  },
    { "src": "/api/update-kiosk",   "dest": "/api/update-kiosk/index.go"   },
    { "src": "/api/transfer-device", "dest": "/api/admin/index.go?action=transfer-device" },
    { "src": "/api/users",           "dest": "/api/admin/index.go?action=users"           },
    { "src": "/api/expire-check",    "dest": "/api/admin/index.go?action=expire-check"    },
    { "src": "/api/reprovision",     "dest": "/api/admin/index.go?action=reprovision"     },
    { "src": "/api/audit-log",       "dest": "/api/admin/index.go?action=audit-log"       },
    { "src": "/api/extend-device",   "dest": "/api/admin/index.go?action=extend-device"   },
    { "handle": "filesystem" },
    { "src": "/(.*)",         "dest": "/index.html"            }
  ]
}
