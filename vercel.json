{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.go",
      "use": "@vercel/go"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/health",   "dest": "/api/health/index.go"   },
    { "src": "/api/register", "dest": "/api/register/index.go" },
    { "src": "/api/approve",  "dest": "/api/approve/index.go"  },
    { "src": "/api/status",   "dest": "/api/status/index.go"   },
    { "src": "/api/pending",  "dest": "/api/pending/index.go"  },
    { "src": "/api/approved", "dest": "/api/approved/index.go" },
    { "src": "/api/disabled", "dest": "/api/disabled/index.go" },
    { "src": "/api/disable",  "dest": "/api/disable/index.go"  },
    { "src": "/api/remove",         "dest": "/api/remove/index.go"         },
    { "src": "/api/force-approve",  "dest": "/api/force-approve/index.go"  },
    { "src": "/api/update-kiosk",   "dest": "/api/update-kiosk/index.go"   },
    { "src": "/api/transfer-device", "dest": "/api/transfer-device/index.go" },
    { "src": "/api/users",           "dest": "/api/users/index.go"           },
    { "src": "/api/expire-check",    "dest": "/api/expire-check/index.go"    },
    { "src": "/api/reprovision",     "dest": "/api/reprovision/index.go"     },
    { "handle": "filesystem" },
    { "src": "/(.*)",         "dest": "/index.html"            }
  ]
}
